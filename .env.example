JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=PROJ
# Optional: custom Jira sync query. Use {PROJECT_KEY} if you want it to track JIRA_PROJECT_KEY automatically.
# JIRA_SYNC_JQL=project = {PROJECT_KEY} AND statusCategory != Done
JIRA_SYNC_JQL=project = AM AND issuetype = "AS: Test Defect" AND "aspen scrum team[dropdown]" = "ASPEN+ Modernization Team 2" AND assignee = 63cf64f4f6e1b54316164a0d ORDER BY "cf[11521]" ASC, "cf[10128]" ASC, status ASC, updated DESC, Rank ASC
# Optional: Jira custom field used to surface ASPEN Severity in the triage panel.
# JIRA_ASPEN_SEVERITY_FIELD=customfield_10129
PORT=3002
# Optional: frontend dev port for Vite in local-only overrides such as .env.local.
# VITE_PORT=5173
# Optional: override the frontend API proxy target if it should not follow PORT.
# VITE_API_PROXY_TARGET=http://localhost:3002
