{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:check": "tsc -p tsconfig.json --outDir .build-check",
    "start": "node dist/server/src/index.js",
    "backup:restore": "tsx src/scripts/restore-backup.ts",
    "manager-desk:cleanup-carry-forward": "tsx src/scripts/cleanup-manager-desk-carry-forward.ts",
    "auth:create-user": "tsx src/scripts/create-auth-user.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "express": "^4.19.0",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^1.6.0",
    "drizzle-kit": "^0.21.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
