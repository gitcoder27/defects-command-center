{
  "name": "lead-os",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "deploy": "bash scripts/deploy.sh",
    "deploy:prod": "bash scripts/deploy.sh prod",
    "sync:worktrees": "bash scripts/sync-worktrees.sh",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "build:check": "npm run build:check --workspace=client && npm run build:check --workspace=server",
    "guard:data": "bash scripts/check-db-artifacts.sh",
    "backup:restore": "npm run backup:restore --workspace=server --",
    "manager-desk:cleanup-carry-forward": "npm run manager-desk:cleanup-carry-forward --workspace=server --",
    "start": "npm run start --workspace=server",
    "test": "npm run test:server && npm run test:client",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client",
    "test:coverage": "npm run test:coverage --workspace=server && npm run test:coverage --workspace=client",
    "lint": "eslint .",
    "format:check": "prettier --check \"**/*.{json,yml,yaml}\" --ignore-path .gitignore",
    "typecheck": "npm run typecheck --workspace=client && npm run typecheck --workspace=server"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^8.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.1"
  }
}
